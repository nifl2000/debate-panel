{
  "name": "debate-panel",
  "main": "workers/src/index.ts",
  "compatibility_date": "2024-12-05",
  "compatibility_flags": ["nodejs_compat"],
  "upload_source_maps": true,
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "debate-panel-db",
      "database_id": "1b1ffb25-6a1f-401f-9f13-0d41312fe651"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSION_KV",
      "id": "5209b24a855e4ee5bab88f039e1d68e0"
    }
  ],
  "vars": {
    "DEFAULT_MODEL": "@cf/qwen/qwen2.5-72b-instruct"
  }
}
